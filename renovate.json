{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":enableVulnerabilityAlertsWithLabel(security)",
    "helpers:pinGitHubActionDigests",
    "group:dotnetMonorepo",
    "group:nugetMonorepo"
  ],
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,

  "minimumReleaseAge": "3 days",

  "recreateWhen": "never",
  "labels": ["Dependency Management"],

  "packageRules": [
    {
      "description": "Group GitHub Actions updates (digest re-pins keep the # vX comment, e.g. NuGet/login, dessant/lock-threads)",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Do NOT pin digests for first-party / trusted-publisher actions (actions/*, github/*, microsoft/*) or our own org's actions/reusable workflows (reactiveui/*). CodeQL treats those publishers as verified; reactiveui/* reusable workflows are intentionally pinned to @main so every repo picks up shared-workflow changes immediately. Only genuine 3rd-party actions get SHA-pinned.",
      "matchManagers": ["github-actions"],
      "matchPackagePatterns": ["^actions/", "^github/", "^microsoft/", "^reactiveui/"],
      "pinDigests": false
    },
    {
      "description": "Group Xamarin & AndroidX NuGets",
      "matchManagers": ["nuget"],
      "matchPackagePatterns": [
        "^Xamarin\\.",
        "^Xamarin\\.AndroidX\\.",
        "^Xamarin\\.Android\\.Support\\."
      ],
      "groupName": "Xamarin & AndroidX"
    },
{
      "description": "Group Reactive Extensions (Rx.NET) packages",
      "matchManagers": ["nuget"],
      "groupName": "Rx.NET (System.Reactive)",
      "matchPackagePatterns": [
        "^System\\.Reactive(\\.|$)",
        "^Microsoft\\.Reactive\\.",
        "^System\\.Interactive(\\.|$)",
        "^System\\.Linq\\.Async(\\.|$)"
      ]
    },
    {
      "description": "Group .NET test frameworks (xUnit + NUnit + Test SDK)",
      "matchManagers": ["nuget"],
      "matchPackagePatterns": [
        "^xunit(\\.|$)",
        "^NUnit",
        "^Verify\\.",
        "^Microsoft\\.NET\\.Test\\.Sdk$",
        "^coverlet\\."
      ],
      "groupName": ".NET test stack"
    },
    {
      "description": "Group Refit packages",
      "matchManagers": ["nuget"],
      "groupName": "Refit",
      "matchPackagePatterns": ["^Refit(\\.|$)"]
    },
    {
      "description": "Group ReactiveUI family",
      "matchManagers": ["nuget"],
      "groupName": "ReactiveUI",
      "matchPackagePatterns": ["^ReactiveUI(\\.|$)"]
    },
    {
      "description": "Group Avalonia UI ecosystem (incl. Avalonia.ReactiveUI)",
      "matchManagers": ["nuget"],
      "groupName": "Avalonia",
      "matchPackagePatterns": ["^Avalonia(\\.|$)"]
    },
    {
      "description": "Group Uno Platform packages",
      "matchManagers": ["nuget"],
      "groupName": "Uno Platform",
      "matchPackagePatterns": ["^Uno(\\.|$)"]
    },
    {
      "description": "Group Splat packages",
      "matchManagers": ["nuget"],
      "groupName": "Splat",
      "matchPackagePatterns": ["^Splat(\\.|$)"]
    },
    {
      "description": "Group NuGet client libraries (NuGet/NuGet.Client family)",
      "matchManagers": ["nuget"],
      "groupName": "NuGet client",
      "matchPackagePatterns": ["^NuGet\\."]
    },
    {
      "description": "Group Microsoft.Extensions.* and Microsoft.Bcl.* (lockstep with .NET runtime cadence)",
      "matchManagers": ["nuget"],
      "groupName": "Microsoft.Extensions",
      "matchPackagePatterns": [
        "^Microsoft\\.Extensions\\.",
        "^Microsoft\\.Bcl\\."
      ]
    },
    {
      "description": "Group Microsoft.AspNetCore.* (lockstep via $(AspNetVersion))",
      "matchManagers": ["nuget"],
      "groupName": "ASP.NET Core",
      "matchPackagePatterns": ["^Microsoft\\.AspNetCore\\."]
    },
    {
      "description": "Group .NET MAUI packages (lockstep via $(MauiVersion))",
      "matchManagers": ["nuget"],
      "groupName": ".NET MAUI",
      "matchPackagePatterns": ["^Microsoft\\.Maui(\\.|$)"]
    },
    {
      "description": "Group Roslyn (Microsoft.CodeAnalysis.*) packages",
      "matchManagers": ["nuget"],
      "groupName": "Roslyn (Microsoft.CodeAnalysis)",
      "matchPackagePatterns": ["^Microsoft\\.CodeAnalysis(\\.|$)"]
    },
    {
      "description": "Group Microsoft.Testing.Platform / Extensions (move together)",
      "matchManagers": ["nuget"],
      "groupName": "Microsoft.Testing",
      "matchPackagePatterns": ["^Microsoft\\.Testing\\."]
    },
    {
      "description": "Group SourceLink providers",
      "matchManagers": ["nuget"],
      "groupName": "SourceLink",
      "matchPackagePatterns": ["^Microsoft\\.SourceLink\\."]
    },
    {
      "description": "Group Microsoft App Center SDK",
      "matchManagers": ["nuget"],
      "groupName": "App Center",
      "matchPackagePatterns": ["^Microsoft\\.AppCenter(\\.|$)"]
    },
    {
      "description": "Group Akavache packages (lockstep release versions)",
      "matchManagers": ["nuget"],
      "groupName": "Akavache",
      "matchPackagePatterns": ["^Akavache(\\.|$)"]
    },
    {
      "description": "Group SQLitePCLRaw bundles & providers",
      "matchManagers": ["nuget"],
      "groupName": "SQLitePCLRaw",
      "matchPackagePatterns": ["^SQLitePCLRaw(\\.|$)"]
    },
    {
      "description": "Group Prism.* packages",
      "matchManagers": ["nuget"],
      "groupName": "Prism",
      "matchPackagePatterns": ["^Prism(\\.|$)"]
    },
    {
      "description": "Group TUnit packages",
      "matchManagers": ["nuget"],
      "groupName": "TUnit",
      "matchPackagePatterns": ["^TUnit(\\.|$)"]
    },
    {
      "description": "Group Roslynator analyzers",
      "matchManagers": ["nuget"],
      "groupName": "Roslynator",
      "matchPackagePatterns": ["^Roslynator(\\.|$)"]
    },
    {
      "description": "Group Microsoft.Windows.* (WindowsAppSDK, SDK build tools, CsWinRT)",
      "matchManagers": ["nuget"],
      "groupName": "Microsoft.Windows",
      "matchPackagePatterns": [
        "^Microsoft\\.Windows\\.",
        "^Microsoft\\.WindowsAppSDK$"
      ]
    },
    {
      "description": "Group Zensical / MkDocs ecosystem (pip)",
      "matchManagers": ["pip_requirements"],
      "groupName": "Zensical & MkDocs",
      "matchPackagePatterns": [
        "^zensical(\\.|$|-)",
        "^mkdocs(\\.|$|-)",
        "^pymdown-extensions$"
      ]
    },
    {
      "description": "ASP.NET Core & MAUI are multi-targeted per .NET major (one PackageVersion per major, selected by IsTargetFrameworkCompatible bands) so each entry stays matched to its TFM. Block cross-major bumps that would collapse those entries onto a single version; within-major patch/minor updates still flow.",
      "matchManagers": ["nuget"],
      "matchPackagePatterns": [
        "^Microsoft\\.AspNetCore\\.",
        "^Microsoft\\.Maui(\\.|$)"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
